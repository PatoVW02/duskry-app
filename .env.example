# Feature flags
# Set both flags to false to run the desktop app without paid plans, limits, paywalls, or Billing UI.
# Vercel/Vite frontend flag:
VITE_BILLING_PLANS_ENABLED=true
# Native Tauri/Rust gate flag:
DUSKRY_BILLING_PLANS_ENABLED=true

# Lemon Squeezy checkout URLs — copy to .env and fill in your values
VITE_CHECKOUT_PRO_MONTHLY=
VITE_CHECKOUT_PRO_YEARLY=
VITE_CHECKOUT_PROPLUS_MONTHLY=
VITE_CHECKOUT_PROPLUS_YEARLY=
