{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duskry",
  "version": "0.7.0",
  "identifier": "app.duskry.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Duskry",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0MTIzRTNDQUU0QkNBRApSV1N0dk9USzR5TkJDeGtlZmFyeFhQZmViZkdrTmRNRnQyN2tjdFFUV1RaUDFjSC9RZlpUcG54Uwo=",
      "endpoints": [
        "https://github.com/PatoVW02/duskry-app/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
